{
  "name": "english-card",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "start \"Backend\" cmd /k \"cd server && pip install -r requirements.txt -q && uvicorn main:app --reload --port 8000\" && vite",
